{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && { tmux set-option -w -t \"$TMUX_PANE\" window-status-style 'bg=blue,fg=white'; tmux set-option -w -t \"$TMUX_PANE\" @busy 1; } 2>/dev/null",
            "async": true,
            "statusMessage": "tmux: mark window busy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && { tmux set-option -uw -t \"$TMUX_PANE\" window-status-style; tmux set-option -uw -t \"$TMUX_PANE\" @busy; } 2>/dev/null",
            "async": true,
            "statusMessage": "tmux: clear window busy"
          },
          {
            "type": "command",
            "command": "zsh -c 'source ~/.config/zsh/win-notify.sh; win-notify \"Task complete.\" \"Claude\"' 2>/dev/null",
            "async": true,
            "statusMessage": "Notifying Windows"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message // \"\"' | { read -r m; case \"$m\" in *\"waiting for your input\"*) exit 0 ;; esac; zsh -c 'source ~/.config/zsh/win-notify.sh; win-notify \"Input needed.\" \"Claude\"' ; [ -n \"$TMUX_PANE\" ] && printf '\\a' > \"$(tmux display-message -p -t \"$TMUX_PANE\" '#{pane_tty}')\" ; } 2>/dev/null",
            "async": true,
            "statusMessage": "Notifying Windows"
          }
        ]
      }
    ]
  }
}
